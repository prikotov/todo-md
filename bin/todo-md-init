#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * todo-md init — initialise a todo/ kanban board in the current project.
 *
 * Usage:
 *   php vendor/prikotov/todo-md/bin/todo-md-init [target-dir]
 *
 *   target-dir  — project root (default: current working directory).
 *
 * What it does:
 *   1. Creates directory structure: todo/, todo/backlog/, todo/done/, todo/cancelled/
 *      (each with .gitkeep so empty dirs are tracked by git).
 *   2. Copies docs/ from the package into docs/todo-md/ (AGENTS.md, guides, references, templates).
 *      Existing files are NOT overwritten — the user is warned instead.
 *   3. Writes docs/todo-md/ into docs/.gitignore so generated docs are not committed.
 *   4. Prints a short post-init instruction.
 */

// ── Resolve paths ──────────────────────────────────────────────────────────

$packageRoot = dirname(__DIR__);
$targetDir   = isset($argv[1]) ? realpath($argv[1]) : getcwd();

if ($targetDir === false || !is_dir($targetDir)) {
    fwrite(STDERR, "Error: target directory does not exist: " . ($argv[1] ?? getcwd()) . PHP_EOL);
    exit(1);
}

$todoDir = $targetDir . '/todo';

// ── 1. Create directory structure ──────────────────────────────────────────

$directories = [
    $todoDir,
    $todoDir . '/backlog',
    $todoDir . '/done',
    $todoDir . '/cancelled',
];

foreach ($directories as $dir) {
    if (!is_dir($dir)) {
        mkdir($dir, 0755, true);
        echo "  Created  $dir/" . PHP_EOL;
    } else {
        echo "  Exists   $dir/" . PHP_EOL;
    }

    $gitkeep = $dir . '/.gitkeep';
    if (!file_exists($gitkeep)) {
        file_put_contents($gitkeep, '');
    }
}

// ── 2. Copy docs into docs/todo-md/ ────────────────────────────────────────

$sourceDocs = $packageRoot . '/docs';
$targetDocs = $targetDir . '/docs/todo-md';

if (!is_dir($sourceDocs)) {
    fwrite(STDERR, "Error: package docs/ not found at $sourceDocs" . PHP_EOL);
    exit(1);
}

if (!is_dir($targetDocs)) {
    mkdir($targetDocs, 0755, true);
}

$copied   = 0;
$skipped  = 0;
$iterator = new RecursiveIteratorIterator(
    new RecursiveDirectoryIterator($sourceDocs, RecursiveDirectoryIterator::SKIP_DOTS),
    RecursiveIteratorIterator::SELF_FIRST,
);

foreach ($iterator as $item) {
    $relativePath = substr($item->getPathname(), strlen($sourceDocs) + 1);
    $targetPath   = $targetDocs . '/' . $relativePath;

    if ($item->isDir()) {
        if (!is_dir($targetPath)) {
            mkdir($targetPath, 0755, true);
        }
        continue;
    }

    if (file_exists($targetPath)) {
        echo "  Skip     docs/todo-md/$relativePath (already exists)" . PHP_EOL;
        $skipped++;
        continue;
    }

    $targetDirForFile = dirname($targetPath);
    if (!is_dir($targetDirForFile)) {
        mkdir($targetDirForFile, 0755, true);
    }

    copy($item->getPathname(), $targetPath);
    echo "  Copied   docs/todo-md/$relativePath" . PHP_EOL;
    $copied++;
}

// ── 3. Copy AGENTS.md to todo/ (committed, not gitignored) ───────────────

$agentsSource = $sourceDocs . '/AGENTS.md';
$agentsTarget = $todoDir . '/AGENTS.md';

if (file_exists($agentsSource) && !file_exists($agentsTarget)) {
    copy($agentsSource, $agentsTarget);
    echo "  Copied   todo/AGENTS.md" . PHP_EOL;
} elseif (file_exists($agentsTarget)) {
    echo "  Skip     todo/AGENTS.md (already exists)" . PHP_EOL;
}

// ── 4. Update docs/.gitignore ──────────────────────────────────────────────

$gitignore  = $targetDir . '/docs/.gitignore';
$entry      = 'todo-md/';
$written    = false;

if (file_exists($gitignore)) {
    $content = file_get_contents($gitignore);
    if (str_contains($content, $entry)) {
        $written = true;
    } else {
        $content = rtrim($content) . PHP_EOL . $entry . PHP_EOL;
        file_put_contents($gitignore, $content);
        $written = true;
    }
} else {
    if (!is_dir(dirname($gitignore))) {
        mkdir(dirname($gitignore), 0755, true);
    }
    file_put_contents($gitignore, $entry . PHP_EOL);
    $written = true;
}

if ($written) {
    echo "  Updated docs/.gitignore (+ todo-md/)" . PHP_EOL;
}

// ── 5. Summary ─────────────────────────────────────────────────────────────

echo PHP_EOL;
echo "Done. $copied file(s) copied, $skipped file(s) skipped." . PHP_EOL;
echo PHP_EOL;
echo "Next steps:" . PHP_EOL;
echo "  1. Add this line to your project's AGENTS.md:" . PHP_EOL;
echo "     * Регламент работы с задачами: [`todo/AGENTS.md`](todo/AGENTS.md)." . PHP_EOL;
echo "  2. Create tasks using template: cp docs/todo-md/templates/task.md todo/TASK-<category>-<name>.todo.md" . PHP_EOL;
